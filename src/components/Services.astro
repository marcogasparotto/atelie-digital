---
// Ajuste os serviços pro que ela realmente oferece.
const services = [
  {
    title: "Encomenda personalizada",
    desc: "Pintura sob medida, na paleta e no tema que você escolher.",
  },
  {
    title: "Composições e conjuntos",
    desc: "Duos e trios pensados pra decorar uma parede inteira.",
  },
  {
    title: "Consultoria de decoração",
    desc: "Ajuda pra escolher o tamanho e o tema ideal pro seu ambiente.",
  },
];
---

<section id="servicos" class="max-w-6xl mx-auto px-6 md:px-10 py-16 md:py-24">
  <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-caramel)] mb-3">o que eu faço</p>
  <h2 class="font-display text-2xl md:text-3xl text-[var(--color-caramel-deep)] mb-10 max-w-md">
    Cada peça, pensada só pra você
  </h2>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {services.map((service, i) => (
      <div class="bg-[var(--color-blush)] rounded-sm p-6">
        <span class="font-display text-2xl text-[var(--color-caramel)]">
          {String(i + 1).padStart(2, "0")}
        </span>
        <h3 class="font-display text-lg mt-4 mb-2">{service.title}</h3>
        <p class="text-sm text-[var(--color-choc)]/70 leading-relaxed">{service.desc}</p>
      </div>
    ))}
  </div>
</section>
