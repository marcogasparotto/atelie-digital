---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-caramel-deep)] text-[var(--color-cream)]">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-12 md:py-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="font-display text-2xl">Ateliê Maria Jove</p>
        <p class="text-sm opacity-75 mt-2 max-w-xs">
          Pinturas autorais em óleo sobre tela, criadas com dedicação,
          sensibilidade e exclusividade para cada cliente.
        </p>
      </div>

      <div class="flex gap-6 text-sm">
        <a href="#portfolio" class="hover:opacity-70 transition-opacity">
          Portfólio
        </a>
        <a href="#sobre" class="hover:opacity-70 transition-opacity">
          Sobre
        </a>
        <a href="#contato" class="hover:opacity-70 transition-opacity">
          Contato
        </a>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-cream)]/20 text-xs opacity-60">
      © {year} Ateliê Maria Jove. Todos os direitos reservados.
    </div>
  </div>
</footer>