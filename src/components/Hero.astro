---
import { Image } from 'astro:assets';
import heroImage from '../assets/hero.jpg';
// Substitua hero.jpg pela foto principal da artista ou por uma obra em destaque.
---

<section class="max-w-6xl mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-16 md:pb-20 grid md:grid-cols-2 gap-10 items-center">

  <div>
    <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-caramel)] mb-4">
      Ateliê de Pintura
    </p>

    <h1 class="font-display text-4xl md:text-6xl leading-[1.05] text-[var(--color-caramel-deep)]">
      Obras que transformam<br />
      ambientes e histórias.
    </h1>

    <p class="mt-6 max-w-md text-[var(--color-choc)]/75 leading-relaxed">
      Bem-vindo ao meu ateliê. Sou <strong>Jove</strong> e desenvolvo pinturas
      autorais em óleo sobre tela, criando obras exclusivas que unem técnica,
      sensibilidade e identidade. Cada pintura é produzida artesanalmente,
      respeitando a inspiração de cada cliente e transformando memórias,
      emoções e referências em uma peça única.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="#contato"
        class="bg-[var(--color-caramel)] text-[var(--color-cream)] px-6 py-3 rounded-full text-sm hover:bg-[var(--color-caramel-deep)] transition-colors"
      >
        Fazer encomenda
      </a>

      <a
        href="#portfolio"
        class="border border-[var(--color-caramel)] text-[var(--color-caramel-deep)] px-6 py-3 rounded-full text-sm hover:bg-[var(--color-blush)] transition-colors"
      >
        Ver portfólio
      </a>
    </div>
  </div>

  <div class="relative aspect-[4/5] overflow-hidden rounded-md shadow-lg">
    <Image
      src={heroImage}
      alt="Obra em destaque do Ateliê Jove"
      width={900}
      class="w-full h-full object-cover"
    />
  </div>

</section>